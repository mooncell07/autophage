{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "autophage",
  "version": "0.1.0",
  "identifier": "com.nova.autophage",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "autophage",
        "width": 800,
        "height": 600,
        "dragDropEnabled": false
    }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
